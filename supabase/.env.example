SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Finnhub (https://finnhub.io - free signup)
FINNHUB_API_KEY=your-finnhub-key

# Google AI Studio (https://aistudio.google.com - free)
GEMINI_API_KEY=your-gemini-key

# TheNewsAPI (https://thenewsapi.com - free signup)
THENEWSAPI_KEY=your-thenewsapi-key

# GitHub PAT (Settings > Developer Settings > Personal Access Tokens)
GITHUB_TOKEN=ghp_your-token-here

# YouTube Data API v3 (https://console.cloud.google.com)
YOUTUBE_API_KEY=your-youtube-key

# Reddit OAuth (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=TechIntel/1.0 by YourUsername

# Stack Exchange (https://stackapps.com/apps/oauth/register)
STACKEXCHANGE_KEY=your-stackexchange-key

# Alpha Vantage (https://www.alphavantage.co/support/#api-key - free)
ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# Product Hunt (https://www.producthunt.com/v2/oauth/applications)
PRODUCTHUNT_CLIENT_ID=your-ph-client-id
PRODUCTHUNT_CLIENT_SECRET=your-ph-client-secret
