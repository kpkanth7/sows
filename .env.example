# ==========================================
# TECH-INTEL v2: Backend Environment Variables
# Copy this file to '.env' and fill in your keys
# ==========================================

# 1. Supabase (Database)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# 2. Google AI Studio (Gemini Consensus Engine)
GEMINI_API_KEY="your-gemini-key"

# 2b. LLM routing
# Default chain is groq -> gemini. Add more providers only if you want them.
# Variable names are case-sensitive.
LLM_PROVIDER="groq"
LLM_PROVIDER_CHAIN="groq,gemini"
LLM_MODEL="openai/gpt-oss-120b"

# 3. Finnhub (Primary Stock Data)
FINNHUB_API_KEY="your-finnhub-key"

# 4. Alpha Vantage (Backup Stock Data)
ALPHA_VANTAGE_KEY="your-alpha-vantage-key"

# 5. TheNewsAPI (Tech Articles)
THENEWSAPI_KEY="your-thenewsapi-key"

# 6. GitHub (Trending & Releases)
# Needs a Personal Access Token (classic) with 'public_repo' scope
GITHUB_TOKEN="ghp_your-github-token-here"

# 7. YouTube Data API v3 (Influencer Tracking)
YOUTUBE_API_KEY="your-youtube-key"

# 8. Reddit API (Community Signals)
# No API keys needed! We use public JSON endpoints.
REDDIT_USER_AGENT="python:tech-intel-scraper:v2.0 (by /u/username)"

# 9. Product Hunt (Startup Launches) - Optional
PRODUCTHUNT_CLIENT_ID="your-ph-client-id"
PRODUCTHUNT_CLIENT_SECRET="your-ph-client-secret"
